#!/usr/bin/env bash
# bin/baremetal-update — pull the latest Shelfarr release and restart on a bare-metal server.

set -euo pipefail

SHELFARR_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$SHELFARR_DIR"

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

step() { echo -e "\n${CYAN}==> $*${NC}"; }
ok()   { echo -e "${GREEN}    ✓ $*${NC}"; }
die()  { echo -e "${RED}ERROR: $*${NC}" >&2; exit 1; }

[[ -f .baremetal-config ]] || die ".baremetal-config not found. Run bin/baremetal-install first."

step "Stopping Shelfarr..."
bin/baremetal-stop

step "Pulling latest code..."
git pull --ff-only
ok "Code updated to $(git describe --tags --always)"

step "Updating gems..."
bundle install --quiet
ok "Gems up to date"

# Load configuration for asset/db tasks
# shellcheck disable=SC1091
source .baremetal-config

step "Precompiling assets..."
bundle exec rails assets:precompile --quiet
ok "Assets compiled"

step "Running database migrations..."
bundle exec rails db:migrate
ok "Migrations complete"

step "Starting Shelfarr..."
bin/baremetal-start

echo ""
echo -e "${GREEN}Update complete.${NC}"
