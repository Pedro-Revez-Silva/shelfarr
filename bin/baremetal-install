#!/usr/bin/env bash
# bin/baremetal-install — first-time setup for Shelfarr on a bare-metal server.
#
# Usage:
#   bash bin/baremetal-install [--port PORT] [--host URL] [--log-level LEVEL]
#
# Flags:
#   --port PORT        Port Puma listens on (e.g. 4567) [required]
#   --host URL         Public URL for the app, e.g. https://shelfarr.example.com [optional]
#   --log-level LEVEL  Rails log level: debug|info|warn|error (default: info)
#   --reconfigure      Re-run the configuration step even if .baremetal-config exists
#
# Configuration is saved to .baremetal-config and loaded automatically by all
# bin/baremetal-* scripts. No manual file editing required.

set -euo pipefail

SHELFARR_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$SHELFARR_DIR"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

step() { echo -e "\n${CYAN}==> $*${NC}"; }
ok()   { echo -e "${GREEN}    ✓ $*${NC}"; }
warn() { echo -e "${YELLOW}    ! $*${NC}"; }
die()  { echo -e "${RED}ERROR: $*${NC}" >&2; exit 1; }

# ─── Parse flags ──────────────────────────────────────────────────────────────

OPT_PORT=""
OPT_HOST=""
OPT_LOG_LEVEL=""
OPT_RECONFIGURE=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --port)        OPT_PORT="$2";       shift 2 ;;
    --port=*)      OPT_PORT="${1#*=}";  shift   ;;
    --host)        OPT_HOST="$2";       shift 2 ;;
    --host=*)      OPT_HOST="${1#*=}";  shift   ;;
    --log-level)   OPT_LOG_LEVEL="$2";  shift 2 ;;
    --log-level=*) OPT_LOG_LEVEL="${1#*=}"; shift ;;
    --reconfigure) OPT_RECONFIGURE=1;   shift   ;;
    *) die "Unknown option: $1. Run 'bash bin/baremetal-install --help' for usage." ;;
  esac
done

# ─── Ruby / rbenv ─────────────────────────────────────────────────────────────

step "Checking Ruby..."

REQUIRED_RUBY="$(cat .ruby-version 2>/dev/null || echo "3.3.6")"

if command -v rbenv &>/dev/null; then
  ok "rbenv found: $(rbenv version)"
  rbenv install "$REQUIRED_RUBY" --skip-existing
  rbenv local "$REQUIRED_RUBY"
elif command -v ruby &>/dev/null; then
  CURRENT_RUBY="$(ruby -e 'puts RUBY_VERSION')"
  if [[ "$CURRENT_RUBY" != "$REQUIRED_RUBY" ]]; then
    warn "System Ruby is $CURRENT_RUBY but Shelfarr requires $REQUIRED_RUBY."
    warn "Install rbenv: https://github.com/rbenv/rbenv#installation"
    warn "Then re-run this script. Continuing with system Ruby — things may break."
  else
    ok "Ruby $CURRENT_RUBY"
  fi
else
  die "Ruby not found. Install rbenv first: https://github.com/rbenv/rbenv#installation"
fi

# ─── Bundler ──────────────────────────────────────────────────────────────────

step "Installing Bundler..."
gem install bundler --no-document --quiet
ok "Bundler $(bundle --version)"

step "Installing gems (production only)..."
bundle config set --local without "development test"
bundle install --quiet
ok "Gems installed"

# ─── Configuration ────────────────────────────────────────────────────────────

CONFIG_FILE=".baremetal-config"

step "Configuring Shelfarr..."

if [[ -f "$CONFIG_FILE" && "$OPT_RECONFIGURE" -eq 0 ]]; then
  ok "$CONFIG_FILE already exists — loading existing configuration"
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
  # Apply any flag overrides on top of the existing config
  [[ -n "$OPT_PORT" ]]      && PORT="$OPT_PORT"
  [[ -n "$OPT_HOST" ]]      && SHELFARR_HOST="$OPT_HOST"
  [[ -n "$OPT_LOG_LEVEL" ]] && RAILS_LOG_LEVEL="$OPT_LOG_LEVEL"
else
  if [[ "$OPT_RECONFIGURE" -eq 1 ]]; then
    echo "  Reconfiguring..."
    # Preserve existing secret keys across reconfiguration
    if [[ -f "$CONFIG_FILE" ]]; then
      EXISTING_KEY="$(grep '^export SECRET_KEY_BASE=' "$CONFIG_FILE" | cut -d'"' -f2 || true)"
      EXISTING_AR_PRIMARY_KEY="$(grep '^export ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=' "$CONFIG_FILE" | cut -d'"' -f2 || true)"
      EXISTING_AR_DETERMINISTIC_KEY="$(grep '^export ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=' "$CONFIG_FILE" | cut -d'"' -f2 || true)"
      EXISTING_AR_KEY_DERIVATION_SALT="$(grep '^export ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=' "$CONFIG_FILE" | cut -d'"' -f2 || true)"
    fi
  fi

  # ── PORT ──────────────────────────────────────────────────────────────────
  if [[ -n "$OPT_PORT" ]]; then
    PORT="$OPT_PORT"
  else
    echo ""
    echo "  Pick a port for Shelfarr's web UI (any available port above 1024, e.g. 4567)."
    echo "  Ensure this port is reachable from your network or reverse proxy."
    read -rp "  Port [4567]: " PORT
    PORT="${PORT:-4567}"
  fi

  if ! [[ "$PORT" =~ ^[0-9]+$ ]] || (( PORT < 1024 || PORT > 65535 )); then
    die "Invalid port: $PORT. Choose a number between 1024 and 65535."
  fi

  # ── HOST (optional) ───────────────────────────────────────────────────────
  if [[ -n "$OPT_HOST" ]]; then
    SHELFARR_HOST="$OPT_HOST"
  else
    echo ""
    echo "  Public URL for Shelfarr (e.g. https://shelfarr.example.com), if you have one."
    echo "  Leave blank to configure later — it only affects notification links."
    read -rp "  Host URL [leave blank]: " SHELFARR_HOST
  fi

  # ── LOG LEVEL (optional) ──────────────────────────────────────────────────
  RAILS_LOG_LEVEL="${OPT_LOG_LEVEL:-info}"

  # ── SECRET KEY ────────────────────────────────────────────────────────────
  # Reuse existing key on reconfigure, generate fresh on first install
  if [[ -n "${EXISTING_KEY:-}" ]]; then
    SECRET_KEY_BASE="$EXISTING_KEY"
    ok "Reusing existing SECRET_KEY_BASE"
  else
    SECRET_KEY_BASE="$(openssl rand -hex 64)"
    ok "Generated SECRET_KEY_BASE"
  fi

  # ── ACTIVE RECORD ENCRYPTION KEYS ────────────────────────────────────────
  # Reuse existing keys on reconfigure, generate fresh on first install
  if [[ -n "${EXISTING_AR_PRIMARY_KEY:-}" ]]; then
    AR_PRIMARY_KEY="$EXISTING_AR_PRIMARY_KEY"
    AR_DETERMINISTIC_KEY="$EXISTING_AR_DETERMINISTIC_KEY"
    AR_KEY_DERIVATION_SALT="$EXISTING_AR_KEY_DERIVATION_SALT"
    ok "Reusing existing Active Record encryption keys"
  else
    AR_PRIMARY_KEY="$(openssl rand -base64 32)"
    AR_DETERMINISTIC_KEY="$(openssl rand -base64 32)"
    AR_KEY_DERIVATION_SALT="$(openssl rand -base64 32)"
    ok "Generated Active Record encryption keys"
  fi
fi

# Write (or rewrite) the config file
cat > "$CONFIG_FILE" <<EOF
# Shelfarr — bare-metal configuration
# Generated by bin/baremetal-install on $(date -u +"%Y-%m-%d %H:%M UTC")
# Re-run 'bin/baremetal-install --reconfigure' to change these values.
export RAILS_ENV=production
export PORT="${PORT}"
export SECRET_KEY_BASE="${SECRET_KEY_BASE}"
export ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY="${AR_PRIMARY_KEY}"
export ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY="${AR_DETERMINISTIC_KEY}"
export ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT="${AR_KEY_DERIVATION_SALT}"
export SOLID_QUEUE_IN_PUMA=1
export RAILS_LOG_LEVEL="${RAILS_LOG_LEVEL}"
export SHELFARR_HOST="${SHELFARR_HOST:-}"
EOF
chmod 600 "$CONFIG_FILE"
ok "Configuration saved to $CONFIG_FILE"

# ─── Directories ──────────────────────────────────────────────────────────────

step "Creating required directories..."
mkdir -p storage tmp/pids tmp/cache tmp/sockets log
ok "storage/, tmp/, log/ ready"

# ─── Source config ────────────────────────────────────────────────────────────

# shellcheck disable=SC1090
source "$CONFIG_FILE"

# Thruster is not used in bare-metal mode; Puma handles HTTP directly
export THRUSTER_ENABLED=false

# ─── Assets ───────────────────────────────────────────────────────────────────

step "Precompiling assets..."
bundle exec rails assets:precompile --quiet
ok "Assets compiled"

# ─── Database ─────────────────────────────────────────────────────────────────

step "Preparing database..."
bundle exec rails db:prepare
ok "Database ready"

step "Seeding default settings..."
bundle exec rails runner 'SettingsService.seed_defaults!'
ok "Settings seeded"

# ─── Done ─────────────────────────────────────────────────────────────────────

echo ""
echo -e "${GREEN}╔══════════════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║     Shelfarr install complete!                      ║${NC}"
echo -e "${GREEN}╚══════════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "Next steps:"
echo -e "  1. Start Shelfarr:"
echo -e "     ${CYAN}bin/baremetal-start${NC}"
echo -e ""
echo -e "  2. Expose port ${CYAN}${PORT}${NC} via your firewall or reverse proxy for external access."
echo -e ""
echo -e "  3. Open Shelfarr → Settings → Paths and update the download/output"
echo -e "     directories to match your server's folder layout."
echo -e ""
echo -e "  To change the port or host later:"
echo -e "     ${CYAN}bin/baremetal-install --reconfigure${NC}"
echo -e ""
echo -e "  Full guide: ${CYAN}docs/baremetal-deployment.md${NC}"
