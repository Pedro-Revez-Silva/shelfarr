<%
  audiobookshelf_matches ||= []
  existing_books_lookup ||= {}
  result_sources = result.respond_to?(:sources) ? Array(result.sources) : [ { source_name: result.source_name, source_url: result.source_url, work_id: result.work_id } ]
  source_work_ids = result_sources.filter_map { |source| source[:work_id] }
  source_work_ids = [ result.work_id ] if source_work_ids.blank?
  content_kind = result.respond_to?(:content_kind) ? result.content_kind.to_s : "book"
  available_book_types = if result.respond_to?(:available_book_types)
    Array(result.available_book_types).compact_blank
  else
    %w[audiobook ebook]
  end
  available_book_types = %w[comicbook] if available_book_types.blank? && %w[comic manga].include?(content_kind)
  available_book_types = %w[audiobook ebook] if available_book_types.blank?

  type_labels = {
    "audiobook" => "Audiobook",
    "ebook" => "Ebook",
    "comicbook" => content_kind == "manga" ? "Manga" : "Comic Book"
  }
  type_classes = {
    "audiobook" => "bg-purple-600 hover:bg-purple-500",
    "ebook" => "bg-blue-600 hover:bg-blue-500",
    "comicbook" => "bg-emerald-600 hover:bg-emerald-500"
  }
  kind_label = case content_kind
  when "comic" then "Comic"
  when "manga" then "Manga"
  else "Book"
  end

  metadata_params = {
    work_id: result.work_id,
    title: result.title,
    author: result.author,
    cover_url: result.cover_url,
    first_publish_year: result.first_publish_year,
    description: (result.description if result.respond_to?(:description)),
    content_kind: content_kind,
    publisher: (result.publisher if result.respond_to?(:publisher)),
    issue_number: (result.issue_number if result.respond_to?(:issue_number)),
    release_date: (result.release_date if result.respond_to?(:release_date)),
    series: (result.series_name if result.respond_to?(:series_name)),
    series_position: (result.series_position if result.respond_to?(:series_position)),
    collection_source: (result.collection_source if result.respond_to?(:collection_source)),
    collection_id: (result.collection_id if result.respond_to?(:collection_id)),
    collection_title: (result.collection_title if result.respond_to?(:collection_title)),
    source_work_ids: source_work_ids,
    available_book_types: available_book_types
  }.compact
%>

<div class="group relative overflow-hidden rounded-xl bg-gray-900 shadow-lg ring-1 ring-gray-800 transition-all duration-300 hover:scale-[1.03] hover:shadow-2xl">
  <div class="relative aspect-[2/3]">
    <%= link_to search_details_path(metadata_params.merge(modal: 1)), class: "block h-full w-full", title: "View details for #{result.title}", data: { turbo_frame: "modal" } do %>
      <% if result.cover_url.present? %>
        <img src="<%= result.cover_url %>" alt="Cover of <%= result.title %>" class="h-full w-full object-cover" loading="lazy">
      <% else %>
        <div class="flex h-full w-full items-center justify-center bg-gray-800 text-sm text-gray-500">No cover</div>
      <% end %>
    <% end %>

    <div class="absolute left-2 top-2 flex flex-col gap-1">
      <span class="rounded bg-black/65 px-2 py-0.5 text-xs font-medium text-white backdrop-blur-sm"><%= kind_label %></span>
      <% if result.first_publish_year.present? %>
        <span class="rounded bg-black/65 px-2 py-0.5 text-xs font-medium text-white backdrop-blur-sm"><%= result.first_publish_year %></span>
      <% end %>
    </div>

    <% if audiobookshelf_matches.any? %>
      <span class="absolute right-2 top-2 rounded bg-amber-500/90 px-2 py-0.5 text-xs font-medium text-white backdrop-blur-sm">Related titles</span>
    <% end %>

    <div class="absolute inset-x-0 bottom-0 flex flex-col gap-2 bg-gradient-to-t from-black via-black/80 to-transparent p-3 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
      <% available_book_types.each do |book_type| %>
        <%
          existing_book = Book.find_in_lookup(existing_books_lookup, source_work_ids, book_type: book_type)
          status = if existing_book&.acquired?
            :acquired
          elsif existing_book&.requests&.active&.any?
            :requested
          else
            :available
          end
        %>
        <% if status == :available %>
          <%= link_to type_labels.fetch(book_type, book_type.titleize), new_request_path(metadata_params.merge(book_type: book_type)), class: "w-full rounded-md px-3 py-2 text-center text-sm font-medium text-white transition-colors #{type_classes.fetch(book_type, 'bg-gray-700 hover:bg-gray-600')}" %>
        <% else %>
          <span class="w-full rounded-md bg-gray-800/90 px-3 py-2 text-center text-sm font-medium text-gray-300">
            <%= type_labels.fetch(book_type, book_type.titleize) %> <%= status == :acquired ? "in library" : "requested" %>
          </span>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="p-3">
    <div class="mb-2 flex flex-wrap gap-1">
      <% result_sources.each do |source| %>
        <% if source[:source_url].present? %>
          <%= link_to source[:source_name], source[:source_url], target: "_blank", rel: "noopener", class: "inline-flex max-w-full items-center rounded-full border border-gray-700 bg-gray-950 px-2 py-0.5 text-[10px] font-medium uppercase text-gray-400 transition hover:border-gray-500 hover:text-gray-200" %>
        <% else %>
          <span class="inline-flex max-w-full items-center rounded-full border border-gray-700 bg-gray-950 px-2 py-0.5 text-[10px] font-medium uppercase text-gray-400"><%= source[:source_name] %></span>
        <% end %>
      <% end %>
    </div>
    <%= link_to search_details_path(metadata_params.merge(modal: 1)), class: "block", data: { turbo_frame: "modal" } do %>
      <h3 class="line-clamp-2 text-sm font-semibold leading-tight text-white hover:text-blue-300"><%= result.title %></h3>
    <% end %>
    <% if result.author.present? %>
      <p class="mt-1 truncate text-xs text-gray-400"><%= result.author %></p>
    <% end %>
    <% if result.respond_to?(:collection_title) && result.collection_title.present? %>
      <p class="mt-1 truncate text-xs text-emerald-300"><%= result.collection_title %></p>
    <% elsif result.series_name.present? %>
      <p class="mt-1 truncate text-xs text-gray-500"><%= result.series_name %></p>
    <% end %>
    <% if audiobookshelf_matches.any? %>
      <p class="mt-2 border-t border-gray-800 pt-2 text-[11px] text-amber-300">Related titles in your library</p>
      <ul class="mt-2 space-y-1">
        <% audiobookshelf_matches.each do |match| %>
          <li class="flex items-start justify-between gap-2 text-[11px]">
            <span class="min-w-0">
              <span class="block truncate text-amber-100"><%= match.item.display_title %></span>
              <% if match.item.author.present? %>
                <span class="block truncate text-amber-200/80"><%= match.item.author %></span>
              <% end %>
              <% detail_badges = match.item.detail_badges.first(3) %>
              <% if detail_badges.any? || match.item.identifier_label.present? %>
                <span class="block truncate text-amber-200/70"><%= ([ *detail_badges, match.item.identifier_label ].compact).join(" · ") %></span>
              <% end %>
            </span>
            <span class="shrink-0 rounded-full bg-amber-500/10 px-2 py-0.5 font-medium text-amber-300"><%= match.confidence_label %></span>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>
</div>
