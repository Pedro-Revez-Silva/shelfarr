<% audible_purchase = @audible_tagged_book_ids.include?(book.id) %>

<article
  class="group flex h-full flex-col overflow-hidden rounded-xl bg-gray-900 shadow-lg ring-1 ring-gray-800 transition-all duration-300 hover:scale-[1.03] hover:shadow-2xl motion-reduce:transition-none motion-reduce:hover:scale-100"
  data-library-card
  data-library-source="shelfarr"
  data-library-book-id="<%= book.id %>"
>
  <%= link_to library_path(book), class: "flex h-full flex-col" do %>
    <div class="relative aspect-[2/3]">
      <% if book.cover_url.present? %>
        <img
          src="<%= book.cover_url %>"
          alt="Cover of <%= book.title %>"
          class="h-full w-full object-cover"
          loading="lazy"
          referrerpolicy="no-referrer"
        >
      <% else %>
        <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-gray-700 to-gray-900">
          <svg class="h-12 w-12 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
        </div>
      <% end %>

      <div class="absolute left-2 top-2 flex flex-col items-start gap-1">
        <span class="rounded bg-green-600/90 px-2 py-0.5 text-xs font-medium text-white backdrop-blur-sm">On server</span>
        <% if audible_purchase %>
          <span class="rounded bg-orange-600/90 px-2 py-0.5 text-xs font-medium text-white backdrop-blur-sm" title="Owned on Audible">Audible</span>
        <% end %>
      </div>
      <span class="absolute right-2 top-2 inline-flex items-center rounded px-2 py-0.5 text-xs font-medium text-white backdrop-blur-sm <%= book.audiobook? ? 'bg-purple-500/90' : 'bg-blue-500/90' %>">
        <%= book.audiobook? ? "Audio" : "Ebook" %>
      </span>

    </div>

    <div class="flex flex-1 flex-col bg-gray-900 p-3">
      <h3 class="line-clamp-2 text-sm font-semibold leading-tight text-white"><%= book.title %></h3>
      <% if book.author.present? %>
        <p class="mt-1 truncate text-xs text-gray-400"><%= book.author %></p>
      <% end %>
      <div class="mt-3 flex-1 text-xs">
        <p class="text-emerald-300">Available on this server</p>
      </div>
      <span class="mt-3 w-full rounded-md bg-blue-600 px-3 py-2 text-center text-sm font-medium text-white group-hover:bg-blue-500">View details</span>
    </div>
  <% end %>
</article>
