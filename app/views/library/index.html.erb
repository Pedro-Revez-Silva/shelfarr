<% if @owned_library_connection %>
  <%= turbo_stream_from @owned_library_connection %>
  <% turbo_refreshes_with(method: :morph, scroll: :preserve) %>
<% end %>

<div class="mx-auto max-w-6xl">
  <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="font-bold text-3xl text-white">Library</h1>
      <p class="mt-1 text-sm text-gray-500">
        <%= @owned_library_connection ? "Everything available to read now or back up, in one catalog." : "Books stored on this server and ready to read or listen to." %>
      </p>
    </div>
    <span class="text-sm text-gray-500"><%= @total_titles %> <%= "title".pluralize(@total_titles) %></span>
  </div>

  <nav class="mb-6 flex flex-wrap gap-2" aria-label="Library filters">
    <%= link_to "All",
      library_index_path(q: @query.presence),
      aria: { current: ("page" if @type_filter.blank? && @source_filter.blank?) },
      class: "rounded-full px-4 py-2 text-sm font-medium transition #{@type_filter.blank? && @source_filter.blank? ? 'bg-white text-gray-900' : 'bg-gray-800 text-gray-400 hover:bg-gray-700 hover:text-white'}" %>
    <%= link_to "Audiobooks",
      library_index_path(type: :audiobook, q: @query.presence),
      aria: { current: ("page" if @type_filter == "audiobook") },
      class: "rounded-full px-4 py-2 text-sm font-medium transition #{@type_filter == 'audiobook' ? 'bg-purple-600 text-white' : 'bg-gray-800 text-gray-400 hover:bg-gray-700 hover:text-white'}" %>
    <%= link_to "Ebooks",
      library_index_path(type: :ebook, q: @query.presence),
      aria: { current: ("page" if @type_filter == "ebook") },
      class: "rounded-full px-4 py-2 text-sm font-medium transition #{@type_filter == 'ebook' ? 'bg-blue-600 text-white' : 'bg-gray-800 text-gray-400 hover:bg-gray-700 hover:text-white'}" %>
    <%= link_to "Audible",
      library_index_path(source: :audible, q: @query.presence),
      aria: { current: ("page" if @source_filter == "audible") },
      class: "rounded-full px-4 py-2 text-sm font-medium transition #{@source_filter == 'audible' ? 'bg-orange-600 text-white' : 'bg-gray-800 text-gray-400 hover:bg-gray-700 hover:text-white'}" %>
  </nav>

  <%= form_with url: library_index_path, method: :get, class: "mb-8 flex flex-wrap gap-2" do |form| %>
    <%= form.hidden_field :type, value: @type_filter if @type_filter.present? %>
    <%= form.hidden_field :source, value: @source_filter if @source_filter.present? %>
    <%= form.label :q, "Filter library by title or author", class: "sr-only" %>
    <%= form.search_field :q,
      value: @query,
      placeholder: "Filter by title or author",
      class: "min-w-64 flex-1 rounded-md border-gray-700 bg-gray-800 text-white" %>
    <%= form.submit "Filter", class: "rounded-md bg-gray-700 px-4 py-2 text-white hover:bg-gray-600" %>
    <% if @query.present? %>
      <%= link_to "Clear", library_index_path(type: @type_filter, source: @source_filter), class: "rounded-md px-4 py-2 text-gray-400 hover:text-white" %>
    <% end %>
  <% end %>

  <% if @show_audible_controls %>
    <div class="mb-5 flex flex-wrap items-center justify-end gap-3">
      <% if @owned_library_connection.sync_active? %>
        <span class="rounded-full bg-blue-500/20 px-2.5 py-1 text-xs font-medium text-blue-300">Audible syncing…</span>
      <% end %>
      <%= link_to "Manage Audible", admin_owned_library_connections_path, class: "text-sm text-blue-400 hover:text-blue-300" %>
    </div>
  <% end %>

  <% if @show_audible_controls %>
    <% waiting_count = @owned_backup_counts.fetch("queued", 0) + @owned_backup_counts.fetch("starting", 0) %>
    <% batch_count = @owned_backup_counts.fetch("pending", 0) %>
    <div id="audible-backup-queue" role="status" aria-live="polite" aria-atomic="true" class="<%= @owned_backup_total.positive? ? 'mb-5 rounded-lg border border-blue-800 bg-blue-950/30 px-4 py-3 text-sm text-blue-200' : 'sr-only' %>">
      <span class="font-medium"><%= @owned_backup_total.positive? ? "#{@owned_backup_total} #{'backup task'.pluralize(@owned_backup_total)} queued or active" : "No Audible backups queued or active" %></span>
      <% queue_parts = [] %>
      <% queue_parts << "#{batch_count} waiting in confirmed batch" if batch_count.positive? %>
      <% queue_parts << "#{waiting_count} waiting" if waiting_count.positive? %>
      <% queue_parts << "#{@owned_backup_counts.fetch('downloading', 0)} backing up" if @owned_backup_counts.fetch("downloading", 0).positive? %>
      <% queue_parts << "#{@owned_backup_counts.fetch('processing', 0)} importing" if @owned_backup_counts.fetch("processing", 0).positive? %>
      <%= " · #{queue_parts.join(' · ')}" if queue_parts.any? %>
      <span class="text-blue-300"> Libation admits and processes one existing-library backup at a time.</span>
    </div>
  <% end %>

  <% if @total_titles.zero? %>
    <div class="py-20 text-center">
      <svg class="mx-auto mb-6 h-20 w-20 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
      </svg>
      <% if @query.present? || @type_filter.present? || @source_filter.present? %>
        <h3 class="mb-2 text-lg font-medium text-gray-300">No titles match these filters</h3>
        <%= link_to "Clear filters", library_index_path, class: "text-blue-400 hover:text-blue-300" %>
      <% else %>
        <h3 class="mb-2 text-lg font-medium text-gray-300">Your library is empty</h3>
        <p class="mb-6 text-gray-500">Requested, uploaded, and synced titles will appear here.</p>
        <%= link_to "Search Books", search_path, class: "inline-flex items-center rounded-lg bg-blue-600 px-5 py-2.5 font-medium text-white transition hover:bg-blue-500" %>
      <% end %>
    </div>
  <% else %>
    <section id="library-catalog" aria-labelledby="library-catalog-heading">
      <h2 id="library-catalog-heading" class="sr-only">Library catalog</h2>
      <div class="grid grid-cols-2 items-stretch gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
        <% @catalog_entries.each do |entry| %>
          <% if entry.book? %>
            <%= render "book_card", book: entry.record %>
          <% else %>
            <%= render "owned_library_item_card", item: entry.record %>
          <% end %>
        <% end %>
      </div>

      <% if @catalog_total_pages > 1 %>
        <div class="mt-5 flex flex-wrap items-center justify-between gap-3 text-sm text-gray-400">
          <p><%= @total_titles %> titles &middot; Page <%= @catalog_page %> of <%= @catalog_total_pages %></p>
          <div class="flex gap-2">
            <% if @catalog_page > 1 %>
              <%= link_to "Previous",
                library_index_path(type: @type_filter, source: @source_filter, q: @query.presence, page: @catalog_page - 1, anchor: "library-catalog"),
                class: "rounded-md bg-gray-800 px-3 py-2 text-white hover:bg-gray-700" %>
            <% end %>
            <% if @catalog_page < @catalog_total_pages %>
              <%= link_to "Next",
                library_index_path(type: @type_filter, source: @source_filter, q: @query.presence, page: @catalog_page + 1, anchor: "library-catalog"),
                class: "rounded-md bg-gray-800 px-3 py-2 text-white hover:bg-gray-700" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </section>
  <% end %>
</div>
