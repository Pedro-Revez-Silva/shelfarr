<div class="mx-auto max-w-2xl">
  <h1 class="font-bold text-4xl mb-8 text-white">My Profile</h1>

  <div class="bg-gray-900 rounded-lg shadow overflow-hidden border border-gray-800">
    <div class="p-6">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-16 h-16 bg-gray-700 rounded-full flex items-center justify-center">
          <span class="text-2xl font-bold text-gray-300"><%= @user.name.first.upcase %></span>
        </div>
        <div>
          <h2 class="text-xl font-semibold text-white"><%= @user.name %></h2>
          <p class="text-gray-400">@<%= @user.username %></p>
          <% if @user.admin? %>
            <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-purple-500/20 text-purple-400 mt-1">Admin</span>
          <% end %>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-4 mb-6">
        <div class="bg-gray-800 rounded-lg p-4 text-center border border-gray-700">
          <p class="text-2xl font-bold text-white"><%= @stats[:total_requests] %></p>
          <p class="text-sm text-gray-400">Total Requests</p>
        </div>
        <div class="bg-green-900/30 rounded-lg p-4 text-center border border-green-800/50">
          <p class="text-2xl font-bold text-green-400"><%= @stats[:completed_requests] %></p>
          <p class="text-sm text-gray-400">Completed</p>
        </div>
        <div class="bg-yellow-900/30 rounded-lg p-4 text-center border border-yellow-800/50">
          <p class="text-2xl font-bold text-yellow-400"><%= @stats[:pending_requests] %></p>
          <p class="text-sm text-gray-400">Pending</p>
        </div>
      </div>

      <dl class="grid grid-cols-2 gap-4 text-sm border-t border-gray-700 pt-6">
        <div>
          <dt class="text-gray-500">Member since</dt>
          <dd class="font-medium text-gray-200"><%= @user.created_at.strftime("%B %d, %Y") %></dd>
        </div>
        <div>
          <dt class="text-gray-500">Username</dt>
          <dd class="font-medium text-gray-200">@<%= @user.username %></dd>
        </div>
        <div>
          <dt class="text-gray-500">Two-Factor Authentication</dt>
          <dd class="font-medium">
            <% if @user.otp_enabled? %>
              <span class="inline-flex items-center text-green-400">
                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                Enabled
              </span>
            <% else %>
              <span class="text-gray-500">Not enabled</span>
            <% end %>
          </dd>
        </div>
        <% if SettingsService.oidc_configured? %>
          <div>
            <dt class="text-gray-500">OIDC Sign-In</dt>
            <dd class="font-medium">
              <% if @user.oidc_user? %>
                <span class="inline-flex items-center text-green-400">
                  <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  Linked to <%= SettingsService.get(:oidc_provider_name, default: "SSO") %>
                </span>
              <% else %>
                <span class="text-gray-500">Not linked</span>
              <% end %>
            </dd>
          </div>
        <% end %>
        <% if SettingsService.get(:telegram_enabled, default: false) %>
          <div>
            <dt class="text-gray-500">Telegram</dt>
            <dd class="font-medium">
              <% if @user.telegram_linked? %>
                <span class="inline-flex items-center text-green-400">
                  <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  Linked<%= @user.telegram_username.present? ? " to @#{@user.telegram_username}" : "" %>
                </span>
              <% elsif @user.telegram_link_token_created_at.present? && @user.telegram_link_token_created_at >= User::TELEGRAM_LINK_CODE_TTL.ago %>
                <span class="text-yellow-400">Link code active</span>
              <% else %>
                <span class="text-gray-500">Not linked</span>
              <% end %>
            </dd>
          </div>
        <% end %>
      </dl>
    </div>

    <div class="px-6 py-4 bg-gray-800 border-t border-gray-700 flex flex-wrap gap-4">
      <%= link_to "Edit Profile", edit_profile_path, class: "px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white font-medium rounded-lg transition" %>
      <%= link_to "Change Password", password_profile_path, class: "px-4 py-2 bg-gray-700 hover:bg-gray-600 text-gray-300 font-medium rounded-lg transition" %>
      <% if SettingsService.oidc_configured? && !@user.oidc_user? %>
        <%= button_to "Link OIDC Login", link_oidc_profile_path, method: :post, form: { data: { turbo: false } }, class: "px-4 py-2 bg-indigo-700 hover:bg-indigo-600 text-white font-medium rounded-lg transition cursor-pointer" %>
      <% end %>
      <% if SettingsService.get(:telegram_enabled, default: false) %>
        <% if @user.telegram_linked? %>
          <%= button_to "Unlink Telegram", unlink_telegram_profile_path, method: :delete, class: "px-4 py-2 bg-gray-700 hover:bg-gray-600 text-gray-300 font-medium rounded-lg transition cursor-pointer" %>
        <% else %>
          <%= button_to "Generate Telegram Code", generate_telegram_link_code_profile_path, method: :post, class: "px-4 py-2 bg-gray-700 hover:bg-gray-600 text-gray-300 font-medium rounded-lg transition cursor-pointer" %>
        <% end %>
      <% end %>
      <%= link_to two_factor_profile_path, class: "px-4 py-2 #{@user.otp_enabled? ? 'bg-green-900/50 text-green-400 hover:bg-green-900/70' : 'bg-yellow-900/50 text-yellow-400 hover:bg-yellow-900/70'} font-medium rounded-lg transition" do %>
        <span class="flex items-center">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
          <%= @user.otp_enabled? ? "Manage 2FA" : "Enable 2FA" %>
        </span>
      <% end %>
    </div>

    <% if SettingsService.oidc_configured? && @user.oidc_user? %>
      <div class="border-t border-gray-700 bg-gray-900/40 px-6 py-5">
        <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div class="max-w-xl">
            <p class="text-sm font-medium text-gray-200">Linked OIDC account</p>
            <p class="mt-1 text-sm text-gray-400">
              This account is linked to <%= SettingsService.get(:oidc_provider_name, default: "SSO") %>.
              Enter your current local password to remove the link and return to password-only sign-in for this account.
            </p>
          </div>

          <%= form_with url: unlink_oidc_profile_path, method: :delete, class: "flex w-full flex-col gap-3 md:w-auto md:min-w-[24rem] md:flex-row" do |form| %>
            <%= form.password_field :current_password, required: !SettingsService.auth_disabled?, autocomplete: "current-password", placeholder: "Current password", class: "w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-2 text-white placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
            <%= form.submit "Unlink OIDC Login", class: "rounded-lg bg-red-700 px-4 py-2 font-medium text-white transition hover:bg-red-600 cursor-pointer whitespace-nowrap" %>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="border-t border-gray-700 bg-gray-900/40 px-6 py-5">
      <div class="flex flex-col gap-5">
        <div>
          <p class="text-sm font-medium text-gray-200">API tokens</p>
          <p class="mt-1 text-sm text-gray-400">Create scoped tokens for bots, scripts, and external tools.</p>
        </div>

        <%= form_with url: api_tokens_profile_path, method: :post, class: "grid gap-3 md:grid-cols-[minmax(0,1fr)_auto]" do |form| %>
          <%= form.text_field :name, placeholder: "Token name", class: "w-full rounded-lg border border-gray-700 bg-gray-800 px-4 py-2 text-white placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
          <%= form.submit "Create API Token", class: "rounded-lg bg-blue-700 px-4 py-2 font-medium text-white transition hover:bg-blue-600 cursor-pointer" %>
          <div class="flex flex-wrap gap-4 text-sm text-gray-300 md:col-span-2">
            <% [["search:read", "Search"], ["requests:read", "Read requests"], ["requests:write", "Create/cancel requests"]].each do |scope, label| %>
              <label class="inline-flex items-center gap-2">
                <%= check_box_tag "scopes[]", scope, true, class: "rounded border-gray-600 bg-gray-700 text-blue-600 focus:ring-blue-500" %>
                <span><%= label %></span>
              </label>
            <% end %>
          </div>
        <% end %>

        <% if @api_tokens.any? %>
          <div class="space-y-2">
            <% @api_tokens.each do |token| %>
              <div class="flex flex-col gap-3 rounded-lg border border-gray-800 bg-gray-950/50 px-4 py-3 md:flex-row md:items-center md:justify-between">
                <div>
                  <p class="text-sm font-medium text-gray-200"><%= token.name %></p>
                  <p class="text-xs text-gray-500">
                    <%= token.token_prefix %>...
                    · <%= token.scope_list.join(", ") %>
                    · <%= token.revoked? ? "revoked" : "active" %>
                    <% if token.last_used_at.present? %>
                      · last used <%= time_ago_in_words(token.last_used_at) %> ago
                    <% end %>
                  </p>
                </div>
                <% unless token.revoked? %>
                  <%= button_to "Revoke", api_token_profile_path(token), method: :delete, class: "rounded-lg bg-red-700 px-3 py-2 text-sm font-medium text-white transition hover:bg-red-600 cursor-pointer" %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
